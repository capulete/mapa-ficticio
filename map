<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forja de Mundos — Gerador de Mapas RPG</title>
<link href="https://fonts.googleapis.com/css2?family=MedievalSharp&family=Cinzel:wght@400;600;900&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --parchment: #f4e8c1;
    --parchment-dark: #dfc98a;
    --ink: #2c1a0e;
    --ink-light: #5c3d1e;
    --blood: #8b1a1a;
    --forest: #2d5016;
    --ocean: #1a3a5c;
    --mountain: #4a3728;
    --gold: #c8960c;
    --shadow: rgba(44,26,14,0.4);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #1a0f08;
    font-family: 'Crimson Pro', serif;
    color: var(--ink);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Noise texture overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.3;
  }

  header {
    text-align: center;
    padding: 24px 20px 16px;
    background: linear-gradient(180deg, #0d0700 0%, #1a0f08 100%);
    border-bottom: 2px solid var(--gold);
    position: relative;
  }

  header::after {
    content: '❧ ✦ ❧';
    display: block;
    color: var(--gold);
    font-size: 14px;
    margin-top: 6px;
    letter-spacing: 8px;
    opacity: 0.7;
  }

  h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(22px, 5vw, 42px);
    font-weight: 900;
    color: var(--parchment);
    letter-spacing: 4px;
    text-shadow: 0 0 30px rgba(200,150,12,0.5), 2px 2px 0 #0d0700;
  }

  h1 span {
    color: var(--gold);
  }

  .subtitle {
    font-family: 'Crimson Pro', serif;
    font-style: italic;
    color: var(--parchment-dark);
    font-size: 14px;
    margin-top: 4px;
    opacity: 0.8;
  }

  .layout {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px 16px;
  }

  @media (min-width: 900px) {
    .layout { flex-direction: row; gap: 20px; }
  }

  /* ===== SIDEBAR ===== */
  .sidebar {
    width: 100%;
    max-width: 340px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  @media (min-width: 900px) { .sidebar { width: 300px; } }

  .panel {
    background: linear-gradient(145deg, #f7edcf, #ede0b0);
    border: 2px solid var(--parchment-dark);
    border-radius: 4px;
    padding: 16px;
    box-shadow: 0 4px 20px var(--shadow), inset 0 1px 0 rgba(255,255,255,0.4);
    position: relative;
  }

  .panel::before {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px solid rgba(200,150,12,0.2);
    border-radius: 2px;
    pointer-events: none;
  }

  .panel-title {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--blood);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--parchment-dark);
  }

  .btn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .terrain-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 10px 6px;
    background: linear-gradient(145deg, #ede0b0, #dfc98a);
    border: 1.5px solid var(--parchment-dark);
    border-radius: 3px;
    cursor: pointer;
    font-family: 'Crimson Pro', serif;
    font-size: 11px;
    color: var(--ink-light);
    transition: all 0.15s;
    user-select: none;
  }

  .terrain-btn:hover { background: linear-gradient(145deg, #f0e8c0, #e8d498); transform: translateY(-1px); }
  .terrain-btn.active {
    background: var(--ink);
    color: var(--parchment);
    border-color: var(--gold);
    box-shadow: 0 0 10px rgba(200,150,12,0.4);
  }

  .terrain-btn .icon { font-size: 22px; }

  .action-btn {
    width: 100%;
    padding: 12px;
    background: linear-gradient(145deg, var(--blood), #6b1313);
    color: var(--parchment);
    border: 1.5px solid #a82020;
    border-radius: 3px;
    cursor: pointer;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    transition: all 0.2s;
    margin-top: 8px;
  }

  .action-btn:hover { background: linear-gradient(145deg, #a82020, #8b1a1a); box-shadow: 0 4px 14px rgba(139,26,26,0.5); }
  .action-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .action-btn.secondary {
    background: linear-gradient(145deg, var(--ink-light), var(--ink));
    border-color: var(--ink);
  }
  .action-btn.secondary:hover { box-shadow: 0 4px 14px rgba(44,26,14,0.5); }

  .action-btn.gold-btn {
    background: linear-gradient(145deg, #c8960c, #a07808);
    border-color: #d4a010;
  }
  .action-btn.gold-btn:hover { box-shadow: 0 4px 14px rgba(200,150,12,0.5); }

  textarea {
    width: 100%;
    background: rgba(255,255,255,0.4);
    border: 1.5px solid var(--parchment-dark);
    border-radius: 3px;
    padding: 10px;
    font-family: 'Crimson Pro', serif;
    font-size: 13px;
    color: var(--ink);
    resize: vertical;
    min-height: 80px;
    outline: none;
    transition: border-color 0.2s;
  }

  textarea:focus { border-color: var(--gold); }
  textarea::placeholder { color: var(--ink-light); opacity: 0.6; font-style: italic; }

  .city-list {
    max-height: 180px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .city-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    background: rgba(255,255,255,0.3);
    border: 1px solid var(--parchment-dark);
    border-radius: 3px;
    font-size: 12px;
    cursor: pointer;
    transition: background 0.15s;
  }

  .city-item:hover { background: rgba(200,150,12,0.15); }
  .city-item.selected { background: rgba(200,150,12,0.25); border-color: var(--gold); }

  .city-icon { font-size: 16px; }
  .city-name { flex: 1; font-weight: 600; color: var(--ink); }
  .city-type { font-size: 10px; color: var(--ink-light); font-style: italic; }
  .city-delete { color: var(--blood); cursor: pointer; font-size: 14px; opacity: 0.7; }
  .city-delete:hover { opacity: 1; }

  /* ===== MAP CANVAS ===== */
  .map-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .map-container {
    position: relative;
    background: var(--ocean);
    border: 3px solid var(--parchment-dark);
    border-radius: 4px;
    box-shadow: 0 8px 32px var(--shadow), inset 0 0 60px rgba(0,0,0,0.3);
    overflow: hidden;
    cursor: crosshair;
    min-height: 460px;
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .map-overlay-hint {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(44,26,14,0.8);
    color: var(--parchment);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 11px;
    font-style: italic;
    pointer-events: none;
    white-space: nowrap;
    border: 1px solid rgba(200,150,12,0.3);
  }

  /* ===== AI PANEL ===== */
  .ai-panel {
    background: linear-gradient(145deg, #0d1a0d, #0a150a);
    border: 2px solid #2d5016;
    border-radius: 4px;
    padding: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 0 40px rgba(45,80,22,0.1);
  }

  .ai-title {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    font-weight: 600;
    color: #6dbf47;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #6dbf47;
    box-shadow: 0 0 8px #6dbf47;
    animation: pulse 2s infinite;
  }

  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

  .ai-response {
    background: rgba(0,0,0,0.4);
    border: 1px solid #2d5016;
    border-radius: 3px;
    padding: 12px;
    min-height: 80px;
    font-size: 13px;
    color: #c8e6b0;
    line-height: 1.7;
    font-style: italic;
    white-space: pre-wrap;
  }

  .ai-response.loading { color: #6dbf47; animation: pulse 1s infinite; }

  .map-controls {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .map-controls .action-btn { margin-top: 0; flex: 1; min-width: 120px; font-size: 11px; padding: 9px; }

  /* Modal */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 500;
    align-items: center;
    justify-content: center;
  }

  .modal.open { display: flex; }

  .modal-box {
    background: linear-gradient(145deg, #f7edcf, #ede0b0);
    border: 2px solid var(--gold);
    border-radius: 4px;
    padding: 24px;
    width: 90%;
    max-width: 380px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
  }

  .modal-box h3 {
    font-family: 'Cinzel', serif;
    font-size: 16px;
    color: var(--blood);
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  .modal-box input, .modal-box select {
    width: 100%;
    padding: 10px;
    background: rgba(255,255,255,0.5);
    border: 1.5px solid var(--parchment-dark);
    border-radius: 3px;
    font-family: 'Crimson Pro', serif;
    font-size: 14px;
    color: var(--ink);
    margin-bottom: 10px;
    outline: none;
  }

  .modal-box input:focus, .modal-box select:focus { border-color: var(--gold); }

  .modal-btns { display: flex; gap: 10px; margin-top: 6px; }
  .modal-btns .action-btn { margin-top: 0; }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 10px 14px;
    background: rgba(244,232,193,0.08);
    border-radius: 3px;
    border: 1px solid rgba(200,150,12,0.2);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: var(--parchment-dark);
    font-style: italic;
  }

  .legend-color {
    width: 14px; height: 14px;
    border-radius: 2px;
    border: 1px solid rgba(255,255,255,0.2);
  }
</style>
</head>
<body>

<header>
  <h1>⚔ Forja de <span>Mundos</span> ⚔</h1>
  <p class="subtitle">Gerador de Mapas para RPG com Inteligência Artificial</p>
</header>

<div class="layout">
  <!-- SIDEBAR -->
  <div class="sidebar">

    <!-- Terrenos -->
    <div class="panel">
      <div class="panel-title">🖌 Pincel de Terreno</div>
      <div class="btn-grid">
        <button class="terrain-btn active" data-terrain="ocean" onclick="setTerrain(this)">
          <span class="icon">🌊</span><span>Oceano</span>
        </button>
        <button class="terrain-btn" data-terrain="plains" onclick="setTerrain(this)">
          <span class="icon">🌾</span><span>Planície</span>
        </button>
        <button class="terrain-btn" data-terrain="forest" onclick="setTerrain(this)">
          <span class="icon">🌲</span><span>Floresta</span>
        </button>
        <button class="terrain-btn" data-terrain="mountain" onclick="setTerrain(this)">
          <span class="icon">⛰</span><span>Montanha</span>
        </button>
        <button class="terrain-btn" data-terrain="desert" onclick="setTerrain(this)">
          <span class="icon">🏜</span><span>Deserto</span>
        </button>
        <button class="terrain-btn" data-terrain="swamp" onclick="setTerrain(this)">
          <span class="icon">🌿</span><span>Pântano</span>
        </button>
        <button class="terrain-btn" data-terrain="snow" onclick="setTerrain(this)">
          <span class="icon">❄</span><span>Neve</span>
        </button>
        <button class="terrain-btn" data-terrain="eraser" onclick="setTerrain(this)">
          <span class="icon">🌊</span><span>Apagar</span>
        </button>
      </div>

      <div style="margin-top:12px;">
        <label style="font-size:12px; color:var(--ink-light); font-style:italic; display:block; margin-bottom:4px;">Tamanho do pincel</label>
        <input type="range" id="brushSize" min="1" max="5" value="2" style="width:100%;" oninput="brushSize=+this.value">
      </div>
    </div>

    <!-- Cidades -->
    <div class="panel">
      <div class="panel-title">🏰 Localidades</div>
      <div class="btn-grid" style="margin-bottom:10px;">
        <button class="terrain-btn" data-terrain="city" onclick="setCityMode(this,'city')">
          <span class="icon">🏙</span><span>Cidade</span>
        </button>
        <button class="terrain-btn" data-terrain="village" onclick="setCityMode(this,'village')">
          <span class="icon">🏘</span><span>Aldeia</span>
        </button>
        <button class="terrain-btn" data-terrain="castle" onclick="setCityMode(this,'castle')">
          <span class="icon">🏰</span><span>Castelo</span>
        </button>
        <button class="terrain-btn" data-terrain="dungeon" onclick="setCityMode(this,'dungeon')">
          <span class="icon">💀</span><span>Masmorra</span>
        </button>
        <button class="terrain-btn" data-terrain="port" onclick="setCityMode(this,'port')">
          <span class="icon">⚓</span><span>Porto</span>
        </button>
        <button class="terrain-btn" data-terrain="temple" onclick="setCityMode(this,'temple')">
          <span class="icon">⛩</span><span>Templo</span>
        </button>
      </div>

      <div class="city-list" id="cityList">
        <div style="font-size:12px; font-style:italic; color:var(--ink-light); text-align:center; padding:10px;">
          Nenhuma localidade adicionada ainda...
        </div>
      </div>
    </div>

    <!-- IA -->
    <div class="panel">
      <div class="panel-title">✨ Descreva seu Mundo</div>
      <textarea id="worldDesc" placeholder="Ex: Um reino medieval com florestas sombrias ao norte, um deserto árido ao sul, e um império marítimo controlando os mares..."></textarea>
      <button class="action-btn gold-btn" onclick="generateWithAI()">✦ Gerar com IA ✦</button>
    </div>

  </div>

  <!-- MAP AREA -->
  <div class="map-wrapper">
    <div class="map-container" id="mapContainer">
      <canvas id="mapCanvas"></canvas>
      <div class="map-overlay-hint" id="hint">🖱 Clique e arraste para pintar o terreno</div>
    </div>

    <div class="legend">
      <div class="legend-item"><div class="legend-color" style="background:#1a3a5c"></div> Oceano</div>
      <div class="legend-item"><div class="legend-color" style="background:#7ab648"></div> Planície</div>
      <div class="legend-item"><div class="legend-color" style="background:#2d5016"></div> Floresta</div>
      <div class="legend-item"><div class="legend-color" style="background:#4a3728"></div> Montanha</div>
      <div class="legend-item"><div class="legend-color" style="background:#c8a832"></div> Deserto</div>
      <div class="legend-item"><div class="legend-color" style="background:#3d6b3d"></div> Pântano</div>
      <div class="legend-item"><div class="legend-color" style="background:#c8e0f0"></div> Neve</div>
    </div>

    <div class="map-controls">
      <button class="action-btn secondary" onclick="clearMap()">🗑 Limpar Mapa</button>
      <button class="action-btn secondary" onclick="generateTerrain()">🎲 Gerar Terreno</button>
      <button class="action-btn" onclick="saveMap()">💾 Exportar PNG</button>
    </div>

    <!-- AI RESPONSE -->
    <div class="ai-panel">
      <div class="ai-title"><div class="ai-dot"></div> Oráculo do Mundo</div>
      <div class="ai-response" id="aiResponse">O oráculo aguarda para revelar os segredos do seu mundo... Descreva seu reino e pressione "Gerar com IA" para receber a sabedoria das eras.</div>
    </div>
  </div>
</div>

<!-- CITY MODAL -->
<div class="modal" id="cityModal">
  <div class="modal-box">
    <h3>⚑ Nova Localidade</h3>
    <input type="text" id="cityName" placeholder="Nome da localidade..." maxlength="40">
    <select id="cityTypeSelect">
      <option value="city">🏙 Cidade</option>
      <option value="village">🏘 Aldeia</option>
      <option value="castle">🏰 Castelo</option>
      <option value="dungeon">💀 Masmorra</option>
      <option value="port">⚓ Porto</option>
      <option value="temple">⛩ Templo</option>
    </select>
    <div class="modal-btns">
      <button class="action-btn" onclick="confirmCity()">Confirmar</button>
      <button class="action-btn secondary" onclick="cancelCity()">Cancelar</button>
    </div>
  </div>
</div>

<script>
// ===== STATE =====
const COLS = 60, ROWS = 40;
let grid = Array.from({length:ROWS}, ()=>Array(COLS).fill('ocean'));
let cities = [];
let currentTerrain = 'ocean';
let cityMode = null;
let pendingCity = null;
let brushSize = 2;
let painting = false;

const canvas = document.getElementById('mapCanvas');
const ctx = canvas.getContext('2d');
const container = document.getElementById('mapContainer');

const TERRAIN_COLORS = {
  ocean:    '#1a3a5c',
  plains:   '#7ab648',
  forest:   '#2d5016',
  mountain: '#4a3728',
  desert:   '#c8a832',
  swamp:    '#3d6b3d',
  snow:     '#c8e0f0',
  eraser:   '#1a3a5c',
};

const TERRAIN_TEXTURE = {
  ocean:    '#1e4268',
  plains:   '#8dc955',
  forest:   '#3a6620',
  mountain: '#5c4535',
  desert:   '#d4b840',
  swamp:    '#4a7a4a',
  snow:     '#d8eaf8',
  eraser:   '#1e4268',
};

const CITY_ICONS = {
  city:    '🏙',
  village: '🏘',
  castle:  '🏰',
  dungeon: '💀',
  port:    '⚓',
  temple:  '⛩',
};

// ===== CANVAS SETUP =====
function resizeCanvas() {
  const rect = container.getBoundingClientRect();
  canvas.width = rect.width || 700;
  canvas.height = rect.height || 460;
  drawMap();
}

window.addEventListener('resize', resizeCanvas);
setTimeout(resizeCanvas, 100);

// ===== DRAWING =====
function getCellSize() {
  return { w: canvas.width/COLS, h: canvas.height/ROWS };
}

function drawMap() {
  const {w,h} = getCellSize();
  ctx.clearRect(0,0,canvas.width,canvas.height);

  for(let r=0;r<ROWS;r++) {
    for(let c=0;c<COLS;c++) {
      const t = grid[r][c];
      ctx.fillStyle = TERRAIN_COLORS[t];
      ctx.fillRect(c*w, r*h, w+1, h+1);

      // texture detail
      ctx.fillStyle = TERRAIN_TEXTURE[t];
      ctx.globalAlpha = 0.35;
      if(t==='ocean') {
        if((r+c)%4===0) { ctx.fillRect(c*w+1,r*h+h*0.4,w*0.6,1); }
      } else if(t==='forest') {
        if((r+c)%3===0) ctx.fillRect(c*w+w*0.3,r*h+h*0.1,w*0.4,h*0.6);
      } else if(t==='mountain') {
        if((r+c)%2===0) {
          ctx.beginPath();
          ctx.moveTo(c*w+w*0.5, r*h+h*0.1);
          ctx.lineTo(c*w+w*0.9, r*h+h*0.9);
          ctx.lineTo(c*w+w*0.1, r*h+h*0.9);
          ctx.closePath(); ctx.fill();
        }
      }
      ctx.globalAlpha = 1;
    }
  }

  // Grid lines subtle
  ctx.strokeStyle = 'rgba(0,0,0,0.06)';
  ctx.lineWidth = 0.5;
  for(let r=0;r<=ROWS;r++) { ctx.beginPath();ctx.moveTo(0,r*h);ctx.lineTo(canvas.width,r*h);ctx.stroke(); }
  for(let c=0;c<=COLS;c++) { ctx.beginPath();ctx.moveTo(c*w,0);ctx.lineTo(c*w,canvas.height);ctx.stroke(); }

  // Vignette
  const vg = ctx.createRadialGradient(canvas.width/2,canvas.height/2,canvas.width*0.3,canvas.width/2,canvas.height/2,canvas.width*0.75);
  vg.addColorStop(0,'transparent');
  vg.addColorStop(1,'rgba(0,0,0,0.35)');
  ctx.fillStyle=vg; ctx.fillRect(0,0,canvas.width,canvas.height);

  // Cities
  const fs = Math.min(w,h)*1.5;
  ctx.font = `${fs}px serif`;
  ctx.textAlign='center'; ctx.textBaseline='middle';
  for(const city of cities) {
    const x = city.col*w + w/2;
    const y = city.row*h + h/2;
    // Shadow glow
    ctx.shadowColor='rgba(0,0,0,0.8)'; ctx.shadowBlur=6;
    ctx.fillText(CITY_ICONS[city.type], x, y);
    ctx.shadowBlur=0;
    // Label
    if(fs>10) {
      ctx.font=`bold ${Math.max(8,fs*0.55)}px Cinzel, serif`;
      ctx.fillStyle='rgba(244,232,193,0.95)';
      ctx.strokeStyle='rgba(44,26,14,0.9)'; ctx.lineWidth=2.5;
      ctx.strokeText(city.name, x, y+fs*0.75);
      ctx.fillText(city.name, x, y+fs*0.75);
      ctx.font = `${fs}px serif`;
    }
  }

  // Compass rose
  drawCompass();
}

function drawCompass() {
  const x=canvas.width-50, y=50, r=28;
  ctx.save();
  ctx.shadowColor='rgba(0,0,0,0.5)'; ctx.shadowBlur=8;
  ctx.fillStyle='rgba(244,232,193,0.85)';
  ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fill();
  ctx.strokeStyle='#c8960c'; ctx.lineWidth=2;
  ctx.stroke(); ctx.shadowBlur=0;

  ctx.fillStyle='#2c1a0e';
  ctx.font='bold 11px Cinzel, serif';
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText('N',x,y-r+10);
  ctx.fillText('S',x,y+r-10);
  ctx.fillText('L',x+r-10,y);
  ctx.fillText('O',x-r+10,y);

  ctx.strokeStyle='#8b1a1a'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.moveTo(x,y-r+14); ctx.lineTo(x,y); ctx.stroke();
  ctx.strokeStyle='#4a3728'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(x,y); ctx.lineTo(x,y+r-14); ctx.stroke();
  ctx.restore();
}

// ===== INTERACTION =====
function getCell(e) {
  const rect = canvas.getBoundingClientRect();
  const {w,h} = getCellSize();
  const scaleX = canvas.width/rect.width;
  const scaleY = canvas.height/rect.height;
  const px = (e.clientX-rect.left)*scaleX;
  const py = (e.clientY-rect.top)*scaleY;
  return { col: Math.floor(px/w), row: Math.floor(py/h) };
}

function paintCell(e) {
  if(cityMode) {
    const {col,row} = getCell(e);
    pendingCity = {col, row, type: cityMode};
    document.getElementById('cityTypeSelect').value = cityMode;
    document.getElementById('cityName').value = '';
    document.getElementById('cityModal').classList.add('open');
    document.getElementById('cityName').focus();
    return;
  }
  if(!painting) return;
  const {col,row} = getCell(e);
  const half = Math.floor(brushSize/2);
  for(let dr=-half;dr<=half;dr++) {
    for(let dc=-half;dc<=half;dc++) {
      const r=row+dr, c=col+dc;
      if(r>=0&&r<ROWS&&c>=0&&c<COLS) {
        grid[r][c] = currentTerrain==='eraser'?'ocean':currentTerrain;
      }
    }
  }
  drawMap();
}

canvas.addEventListener('mousedown', e=>{ painting=true; paintCell(e); });
canvas.addEventListener('mousemove', e=>{ if(painting&&!cityMode) paintCell(e); });
canvas.addEventListener('mouseup', ()=>painting=false);
canvas.addEventListener('mouseleave', ()=>painting=false);

canvas.addEventListener('touchstart', e=>{ painting=true; paintCell(e.touches[0]); e.preventDefault(); });
canvas.addEventListener('touchmove', e=>{ paintCell(e.touches[0]); e.preventDefault(); });
canvas.addEventListener('touchend', ()=>painting=false);

// ===== TERRAIN MODE =====
function setTerrain(btn) {
  cityMode = null;
  currentTerrain = btn.dataset.terrain;
  document.querySelectorAll('.terrain-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('hint').textContent = '🖱 Clique e arraste para pintar o terreno';
}

function setCityMode(btn, type) {
  cityMode = type;
  document.querySelectorAll('.terrain-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('hint').textContent = '📍 Clique no mapa para posicionar a localidade';
}

// ===== CITY MODAL =====
function confirmCity() {
  const name = document.getElementById('cityName').value.trim();
  if(!name) { document.getElementById('cityName').style.borderColor='var(--blood)'; return; }
  const type = document.getElementById('cityTypeSelect').value;
  cities.push({...pendingCity, name, type});
  renderCityList();
  drawMap();
  document.getElementById('cityModal').classList.remove('open');
  cityMode = null;
  document.querySelectorAll('.terrain-btn').forEach(b=>b.classList.remove('active'));
  document.querySelector('[data-terrain="ocean"]').classList.add('active');
}

function cancelCity() {
  document.getElementById('cityModal').classList.remove('open');
  cityMode=null;
  pendingCity=null;
}

document.getElementById('cityName').addEventListener('keydown', e=>{ if(e.key==='Enter') confirmCity(); });

function renderCityList() {
  const list = document.getElementById('cityList');
  if(!cities.length) {
    list.innerHTML='<div style="font-size:12px;font-style:italic;color:var(--ink-light);text-align:center;padding:10px;">Nenhuma localidade adicionada ainda...</div>';
    return;
  }
  list.innerHTML = cities.map((c,i)=>`
    <div class="city-item" onclick="selectCity(${i})">
      <span class="city-icon">${CITY_ICONS[c.type]}</span>
      <span class="city-name">${c.name}</span>
      <span class="city-type">${c.type}</span>
      <span class="city-delete" onclick="deleteCity(event,${i})">✕</span>
    </div>
  `).join('');
}

function selectCity(i) {
  const {w,h} = getCellSize();
  const c = cities[i];
  // highlight
  drawMap();
  ctx.strokeStyle='#gold'; ctx.lineWidth=2;
  ctx.strokeRect(c.col*w-2, c.row*h-2, w+4, h+4);
}

function deleteCity(e,i) {
  e.stopPropagation();
  cities.splice(i,1);
  renderCityList();
  drawMap();
}

// ===== MAP UTILS =====
function clearMap() {
  if(!confirm('Limpar todo o mapa e localidades?')) return;
  grid = Array.from({length:ROWS},()=>Array(COLS).fill('ocean'));
  cities=[];
  renderCityList();
  drawMap();
}

function generateTerrain() {
  // Procedural noise-based terrain
  const cx=COLS/2+Math.random()*10-5, cy=ROWS/2+Math.random()*10-5;
  const islandR = Math.min(COLS,ROWS)*0.35;

  for(let r=0;r<ROWS;r++) {
    for(let c=0;c<COLS;c++) {
      const dx=c-cx, dy=r-cy;
      const dist=Math.sqrt(dx*dx+dy*dy);
      const noise = (Math.sin(c*0.4+Math.random())*Math.cos(r*0.4)+1)*0.5;
      const falloff = 1-Math.min(1,dist/(islandR*(0.8+noise*0.4)));

      if(falloff<0.05) { grid[r][c]='ocean'; continue; }

      const h = falloff+noise*0.3;
      if(h>0.85) grid[r][c]='mountain';
      else if(h>0.7) grid[r][c]='forest';
      else if(h>0.55) grid[r][c]='plains';
      else if(h>0.4) {
        // edge variation
        const roll = Math.random();
        if(roll<0.2) grid[r][c]='swamp';
        else grid[r][c]='plains';
      }
      else if(h>0.15) {
        const roll=Math.random();
        if(roll<0.1) grid[r][c]='desert';
        else grid[r][c]='ocean';
      }
      else grid[r][c]='ocean';
    }
  }

  // Add some desert biome
  const dRow=Math.floor(Math.random()*ROWS*0.6+ROWS*0.2);
  const dCol=Math.floor(Math.random()*COLS*0.6+COLS*0.2);
  for(let r=dRow-4;r<dRow+5;r++) for(let c=dCol-6;c<dCol+7;c++) {
    if(r>=0&&r<ROWS&&c>=0&&c<COLS&&grid[r][c]==='plains') grid[r][c]='desert';
  }

  // Snow in north
  for(let r=0;r<4;r++) for(let c=0;c<COLS;c++) {
    if(grid[r][c]!=='ocean'&&Math.random()<0.6) grid[r][c]='snow';
  }

  drawMap();
}

function saveMap() {
  const link = document.createElement('a');
  link.download = 'mapa-rpg.png';
  link.href = canvas.toDataURL();
  link.click();
}

// ===== AI GENERATION =====
async function generateWithAI() {
  const desc = document.getElementById('worldDesc').value.trim();
  if(!desc) {
    document.getElementById('worldDesc').style.borderColor='var(--blood)';
    setTimeout(()=>document.getElementById('worldDesc').style.borderColor='',1500);
    return;
  }

  const aiBox = document.getElementById('aiResponse');
  aiBox.className = 'ai-response loading';
  aiBox.textContent = '✦ O oráculo consulta os pergaminhos antigos...';

  // Generate terrain based on description
  generateTerrain();

  const cityCount = cities.length;
  const cityNames = cities.map(c=>c.name).join(', ');

  const prompt = `Você é um narrador de RPG de fantasia medieval. O mundo foi descrito como: "${desc}".
${cityCount>0 ? `As seguintes localidades existem neste mundo: ${cityNames}.` : ''}

Crie uma descrição épica e atmosférica deste mundo em 3-4 parágrafos curtos. Inclua:
- A história e lore do mundo
- Os perigos e mistérios das regiões
- Facções, conflitos ou segredos
- Ganchos de aventura para os jogadores

Escreva em português do Brasil com tom de narrador épico medieval. Seja conciso mas envolvente.`;

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        messages: [{ role: "user", content: prompt }]
      })
    });

    const data = await response.json();
    const text = data.content?.map(b=>b.text||'').join('') || 'O oráculo permanece em silêncio...';
    aiBox.className='ai-response';
    typewriter(aiBox, text);

    // Auto-suggest cities if none exist
    if(cities.length===0) suggestCities(desc);

  } catch(err) {
    aiBox.className='ai-response';
    aiBox.textContent='⚠ O oráculo foi perturbado por forças sombrias. Verifique sua conexão e tente novamente.';
  }
}

async function suggestCities(desc) {
  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body: JSON.stringify({
        model:"claude-sonnet-4-20250514",
        max_tokens:400,
        messages:[{role:"user", content:`Para um mundo de RPG descrito como: "${desc}", sugira 4 localidades importantes. Responda APENAS com JSON válido no formato: [{"name":"Nome","type":"city|village|castle|dungeon|port|temple"}]. Sem texto adicional.`}]
      })
    });
    const data = await response.json();
    const raw = data.content?.map(b=>b.text||'').join('').trim();
    const clean = raw.replace(/```json|```/g,'').trim();
    const suggestions = JSON.parse(clean);

    const {w,h}=getCellSize();
    const positions = [
      {row:10,col:15},{row:8,col:40},{row:25,col:20},{row:28,col:42}
    ];

    suggestions.forEach((s,i)=>{
      if(i<positions.length) {
        cities.push({...positions[i], name:s.name, type:s.type||'city'});
      }
    });
    renderCityList();
    drawMap();
  } catch(e) { /* silent */ }
}

function typewriter(el, text, speed=18) {
  el.textContent='';
  let i=0;
  const interval=setInterval(()=>{
    el.textContent+=text[i]||'';
    i++;
    if(i>=text.length) clearInterval(interval);
  }, speed);
}

// Init
generateTerrain();
</script>
